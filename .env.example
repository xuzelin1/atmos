# 数据库连接（Vercel 部署必填）
# 本地开发：可用本地 Postgres 或 Neon/Supabase 等托管 Postgres
# Vercel 部署：在 Vercel Storage 面板创建 Neon Postgres 后自动注入
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Qwen API（阿里通义千问）
DASHSCOPE_API_KEY="sk-xxxxxxxxxxxx"

# Session 加密密钥（至少 32 字符）
SESSION_SECRET="ai-team-studio-demo-secret-key-min-32-chars-long"